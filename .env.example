TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_numeric_chat_id
# Birden fazla hedef için (virgül/boşluk/noktalı virgül ile ayırabilirsiniz):
# TELEGRAM_CHAT_IDS=123456789,-100987654321

# Groq (console.groq.com) — fiyat motoru LLM + isteğe bağlı uyarı özeti
GROQ_API_KEY=
# Örnek: llama-3.3-70b-versatile, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile
# Groq gerekince (HTML’de fiyat yoksa) çağrılar arası bekleme — düşük değer 429 riski
GROQ_MIN_INTERVAL_SECONDS=12
# Fiyat motoru: auto | groq | playwright — auto: GROQ_API_KEY varsa Groq, yoksa Playwright
PRICE_ENGINE=auto

CHECK_INTERVAL=300
PRODUCTS_FILE=data/products.json
ALERT_CACHE_FILE=data/alert_cache.json
ALERT_COOLDOWN_SECONDS=1800
MAX_CONCURRENCY=4

DEFAULT_ALERT_BELOW_TRY=0
DEFAULT_ALERT_DISCOUNT_TRY=0
QUIET_THRESHOLD_SKIPS=true
